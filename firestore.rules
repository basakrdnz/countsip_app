rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if two users are friends
    function areFriends(userId1, userId2) {
      return exists(/databases/$(database)/documents/friendships/$(userId1 + '_' + userId2))
          || exists(/databases/$(database)/documents/friendships/$(userId2 + '_' + userId1));
    }

    // Users Collection
    match /users/{userId} {
      // Owner can read full profile; others can only read public fields
      allow read: if isSignedIn();
      // Only the user can update their own profile
      allow write: if isOwner(userId);

      // Badges subcollection - stored under each user
      match /badges/{badgeId} {
        allow read: if isSignedIn();
        // Owner can write their own badges (client-side badge check)
        allow write: if isOwner(userId);
      }
    }

    // Usernames mapping for uniqueness check
    match /usernames/{username} {
      // Only signed-in users can look up usernames (not public)
      allow read: if isSignedIn();
      // Allow reservation if signing up or updating own username
      allow write: if isSignedIn() && (request.resource.data.uid == request.auth.uid || resource.data.uid == request.auth.uid);
    }

    // Phone number hashes for uniqueness check
    match /phoneNumbers/{hash} {
      // Signed-in users can check if a phone is registered
      allow read: if isSignedIn();
      // Allow creation during signup (uid must match auth user)
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      // No updates or deletes
      allow update, delete: if false;
    }

    // Drink/Alcohol entries
    match /entries/{entryId} {
      // Owner can always read their own entries
      // Friends can read entries (for social feed)
      allow read: if isSignedIn() && (
        isOwner(resource.data.userId) ||
        areFriends(request.auth.uid, resource.data.userId)
      );

      // Only the owner can create/delete their logs
      allow create: if isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);

      // Update: allow owner to change anything, OR allow friends to ONLY toggle 'cheers'
      allow update: if isOwner(resource.data.userId)
                    || (isSignedIn()
                        && areFriends(request.auth.uid, resource.data.userId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cheers']));
    }

    // Notifications
    match /notifications/{notifId} {
      // Allow read/update/delete if the user is the recipient
      allow read, update, delete: if isOwner(resource.data.to);
      // Only signed-in users can create, and must set 'from' to their own uid
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
    }

    // Friend Requests
    match /friend_requests/{requestId} {
      // Sender or receiver can read
      allow read: if isSignedIn() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      // Signed-in users can send friend requests (from must be self)
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
      // Sender or receiver can update status (accept/decline)
      allow update: if isSignedIn() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      // Sender or receiver can delete
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    // Friendships
    match /friendships/{friendshipId} {
       // Users involved in a friendship can read it
       allow read: if isSignedIn() && (request.auth.uid in resource.data.users);
       // Allow creation/deletion if you are one of the parties
       allow create: if isSignedIn() && (request.auth.uid in request.resource.data.users);
       allow update, delete: if isSignedIn() && (request.auth.uid in resource.data.users);
    }

    // Blocked Users
    match /blocked_users/{blockId} {
      // Only the blocker can read their blocked list
      allow read: if isSignedIn() && request.auth.uid == resource.data.blockedBy;
      // Signed-in users can block others
      allow create: if isSignedIn() && request.resource.data.blockedBy == request.auth.uid;
      // Only the blocker can unblock
      allow delete: if isSignedIn() && request.auth.uid == resource.data.blockedBy;
      allow update: if false;
    }

    // Badges (top-level - legacy, kept for compatibility)
    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
